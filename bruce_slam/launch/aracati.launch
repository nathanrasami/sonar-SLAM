<launch>
    <arg name="rviz" default="true"/>
    <arg name="enable_slam" default="true"/>
    <arg name="bag_file" default="$(find bruce_slam)/../ARACATI_2017_8bits_full.bag"/>
    <!-- vitesse de rejeu du bag. DISO (méthode directe) se dégrade sous contention
         CPU en combiné (2.1 m standalone -> 3.2-5.5 m combiné). rate:=0.5 laisse
         à DISO le temps de converger comme en standalone (cf. FABLE.md §5 #1). -->
    <arg name="rate" default="1.0"/>
    <!-- source d'odométrie : "diso" = Direct Sonar Odometry (défaut, dérive ≈3.75 m) ;
         "cmd_vel" = intégration des vitesses commandées (dérive ≈15 m — pour ce mode,
         activer ssm.enable:True dans slam_aracati.yaml) ; "gt" = relay /pose_gt (ATE≈0). -->
    <arg name="odom_source" default="diso"/>

    <param name="use_sim_time" value="true"/>

    <!-- aracati2017 package not available — nodes commented out -->
    <!-- <node pkg="aracati2017" name="odom" type="odom" output="screen">
        <remap from="/pose" to="/pose_gt"/>
        <param name="odom_frame_id" value="map"/>
        <param name="base_frame_id" value="son"/>
    </node> -->

    <!-- <node pkg="aracati2017" name="aerial_image" type="aerial_image" output="screen">
        <remap from="/odom" to="/odom_pose"/>
        <remap from="/pose_gt" to="/pose_gt"/>
        <param name="aerial_image_path" value="$(find aracati2017)/maps/2021-12.yaml"/>
        <param name="son_fov_openning" value="130.0"/>
        <param name="son_min_range" value="0.4"/>
        <param name="son_max_range" value="50.0"/>
    </node> -->

    <!-- rosbag playback -->
    <node pkg="rosbag" name="rosbag_play" type="play" output="screen"
          args="$(arg bag_file) --clock -r $(arg rate) -q"/>

    <!-- Odométrie d'entrée → /direct_sonar/pose (lu par OdomBridge). 3 sources (odom_source) :
         - "diso"    : Direct Sonar Odometry (défaut, odométrie sonar réelle)
         - "cmd_vel" : intégration des vitesses commandées (seedé GT à t=0, puis indépendant)
         - "gt"      : relay /pose_gt → vérité terrain (baseline ATE≈0) -->
    <!-- DISO via binaire direct : le package direct_sonar_odometry n'est plus enregistré
         (rospack ne le trouve plus), seul le binaire dans devel/.private existe → on l'appelle
         via diso_launcher.sh (qui ignore les args ROS et charge config_aracati2017.yaml = prior GT). -->
    <node if="$(eval arg('odom_source') == 'diso')"
          pkg="bruce_slam" type="diso_launcher.sh" name="diso_node" output="screen"/>
    <node if="$(eval arg('odom_source') == 'cmd_vel')"
          pkg="bruce_slam" name="cmd_vel_odom" type="cmd_vel_odom_node.py" output="screen"/>
    <node if="$(eval arg('odom_source') == 'gt')"
          pkg="topic_tools" type="relay" name="gt_to_odom" args="/pose_gt /direct_sonar/pose"/>

    <group ns="bruce">
        <group ns="slam">

            <!-- bridge /odom_pose → /bruce/slam/localization/odom -->
            <node pkg="bruce_slam" name="odom_bridge" type="odom_bridge_node.py" output="screen"/>

            <!-- feature extraction in cartesian mode -->
            <node pkg="bruce_slam" name="feature_extraction" type="feature_extraction_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/feature_aracati.yaml" subst_value="true"/>
            </node>

            <!-- SLAM node -->
            <node pkg="bruce_slam" name="slam" type="slam_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/slam_aracati.yaml" subst_value="true"/>
                <param name="enable_slam" value="$(arg enable_slam)"/>
                <param name="save_fig" value="false"/>
                <param name="save_data" value="true"/>
                <!-- SLAM_RESULTS_DIR hérité de l'environnement (cf. run_slam.sh) ;
                     si absent, le code Python retombe sur results/ par défaut. -->
                <env name="SLAM_RESULTS_DIR" value="$(optenv SLAM_RESULTS_DIR results)"/>
            </node>

        </group>
        <node pkg="tf" name="map_to_world_tf_publisher" type="static_transform_publisher"
              args="0 0 0 0 0 3.14159 world map 100"/>
    </group>

    <node if="$(arg rviz)" type="rviz" name="rviz" pkg="rviz"
          args="-d $(find bruce_slam)/rviz/video.rviz"/>

</launch>
