<launch>
    <!-- REFONTE (REFONTE_MISSION.md) : les 4 méthodes = 2 interrupteurs, rien d'autre.
             sc:=false usbl_backend:=false   → Bruce        (NSSM natif)
             sc:=false usbl_backend:=true    → Bruce_U
             sc:=true  usbl_backend:=false   → Bruce_Sonar
             sc:=true  usbl_backend:=true    → BSU
         Odométrie = cmd_vel_odom PUR (zéro param, seed (0,0,cap 0) ÉTAPE 0) : identique
         dans les 4 méthodes (gate dr ×4). USBL = facteurs unaires back-end UNIQUEMENT
         (⛔3 ; PIEGES #2 double ancrage, PIEGES #25 seed). Les anciens args (usbl,
         gt_free_seed, odom_source, diso_*, usbl_sigma, loop_union, usbl_adaptive,
         heading_from_compass) sont SUPPRIMÉS : la mauvaise config est intapable. -->
    <arg name="sc" default="false"/>
    <arg name="usbl_backend" default="false"/>

    <arg name="rviz" default="true"/>
    <arg name="enable_slam" default="true"/>
    <arg name="bag_file" default="$(find bruce_slam)/../ARACATI_2017_8bits_full.bag"/>
    <arg name="rate" default="1.0"/>

    <param name="use_sim_time" value="true"/>

    <!-- rosbag playback. required=true : à la fin du bag, roslaunch arrête tous les
         nœuds → le SLAM écrit les CSV au on_shutdown (PIEGES #5). -->
    <node pkg="rosbag" name="rosbag_play" type="play" output="screen" required="true"
          args="$(arg bag_file) --clock -r $(arg rate) -q"/>

    <!-- Odométrie d'entrée du SLAM : intégration unicycle de /cmd_vel, publiée sur
         /direct_sonar/pose (PoseStamped). Aucun paramètre (⛔2 odométrie sacrée). -->
    <node pkg="bruce_slam" name="cmd_vel_odom" type="cmd_vel_odom_node.py" output="screen"/>

    <group ns="bruce">
        <group ns="slam">

            <!-- bridge /direct_sonar/pose → /bruce/slam/localization/odom -->
            <node pkg="bruce_slam" name="odom_bridge" type="odom_bridge_node.py" output="screen"/>

            <!-- feature extraction in cartesian mode -->
            <node pkg="bruce_slam" name="feature_extraction" type="feature_extraction_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/feature_aracati.yaml" subst_value="true"/>
            </node>

            <!-- SLAM node : le yaml porte les réglages FIGÉS, le launch ne pilote que
                 les 2 interrupteurs (+ σ USBL lié à la méthode). -->
            <node pkg="bruce_slam" name="slam" type="slam_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/slam_aracati.yaml" subst_value="true"/>
                <param name="sonar_context/enable" value="$(arg sc)"/>
                <param name="usbl/enable" value="$(arg usbl_backend)"/>
                <!-- σ champion par méthode (⛔3, à re-vérifier sur 1 run chacun) :
                     BSU (sc on) = 1.4 · Bruce_U (sc off) = 2.5. Sans effet si
                     usbl_backend:=false. -->
                <param name="usbl/sigma" value="$(eval 1.4 if arg('sc') else 2.5)" type="double"/>
                <param name="enable_slam" value="$(arg enable_slam)"/>
                <param name="save_fig" value="false"/>
                <param name="save_data" value="true"/>
                <!-- SLAM_RESULTS_DIR hérité de l'environnement (cf. run_slam.sh) ;
                     si absent, le code Python retombe sur results/ par défaut. -->
                <env name="SLAM_RESULTS_DIR" value="$(optenv SLAM_RESULTS_DIR results)"/>
            </node>

        </group>
        <node pkg="tf" name="map_to_world_tf_publisher" type="static_transform_publisher"
              args="0 0 0 0 0 3.14159 world map 100"/>
    </group>

    <node if="$(arg rviz)" type="rviz" name="rviz" pkg="rviz"
          args="-d $(find bruce_slam)/rviz/video.rviz"/>

</launch>
