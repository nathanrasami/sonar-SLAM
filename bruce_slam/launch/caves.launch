<launch>
    <!-- Bruce-SLAM sur le dataset CIRS « Underwater Caves » (Mallios et al., IJRR 2017).
         Capteurs (topics STANDARDS, aucun package custom nécessaire) :
           /sonar_micron_ros  sensor_msgs/LaserScan  MSIS Tritech Micron, 1 FAISCEAU/msg
           /odometry          nav_msgs/Odometry      dead-reckoning du dataset (DVL+IMU)
           /imu_adis_ros      sensor_msgs/Imu        (option, pour une odométrie maison)
         GT : éparse (cônes revus par la caméra) → pas de /pose_gt ; l'évaluation ATE
         classique n'est pas disponible en v1 (cf. DATASETS.md).
         Lancement : ./run_slam.sh caves [Bruce|Bruce_Sonar_USBL]
         ⚠ AVANT le premier run : python3 analysis/inspect_bag.py caves.bag
           (valider le format LaserScan supposé par msis_scan_bridge). -->
    <arg name="rviz" default="true"/>
    <arg name="bag_file" default="$(find bruce_slam)/../caves.bag"/>
    <arg name="rate" default="1.0"/>
    <arg name="method" default="bruce"/>   <!-- bruce | bruce_sonar_usbl -->
    <!-- portée du Micron : 0 = lire range_max des LaserScan (à vérifier à l'inspection) -->
    <arg name="sonar_range_m" default="0.0"/>
    <arg name="nssm" default="false"/>

    <param name="use_sim_time" value="true"/>

    <!-- rejeu du bag. required=true : fin de bag → export CSV (invariant GARDE_FOU §2.7) -->
    <node pkg="rosbag" name="rosbag_play" type="play" output="screen" required="true"
          args="$(arg bag_file) --clock -r $(arg rate) -q"/>

    <!-- Odométrie : le dead-reckoning DVL+IMU FOURNI par le dataset (nav_msgs/Odometry),
         relayé tel quel. Alternative future : intégrer /dvl_linkquest + /imu_adis_ros
         nous-mêmes (recette GARDE_FOU §4.B.1). -->
    <node pkg="topic_tools" type="relay" name="odom_relay"
          args="/odometry /bruce/slam/localization/odom"/>

    <group ns="bruce">
        <group ns="slam">

            <!-- MSIS : assemble les faisceaux LaserScan en tours complets → ping polaire -->
            <node pkg="bruce_slam" name="msis_scan_bridge" type="msis_scan_bridge.py"
                  output="screen">
                <param name="scan_topic" value="/sonar_micron_ros"/>
                <param name="range_m" value="$(arg sonar_range_m)"/>
            </node>

            <!-- extraction de features (chaîne POLAIRE, comme holoocean) -->
            <node pkg="bruce_slam" name="feature_extraction" type="feature_extraction_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/feature_caves.yaml" subst_value="true"/>
                <param name="sonar_context/enable"
                       value="$(eval arg('method') == 'bruce_sonar_usbl')"/>
            </node>

            <!-- SLAM — méthode "bruce" -->
            <node if="$(eval arg('method') == 'bruce')"
                  pkg="bruce_slam" name="slam" type="slam_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/slam_caves.yaml" subst_value="true"/>
                <param name="enable_slam" value="true"/>
                <param name="nssm/enable" value="$(arg nssm)"/>
                <param name="save_fig" value="false"/>
                <param name="save_data" value="true"/>
                <env name="SLAM_RESULTS_DIR" value="$(optenv SLAM_RESULTS_DIR results)"/>
            </node>

            <!-- SLAM — méthode "bruce_sonar_usbl" (loops par apparence ; usbl off :
                 pas de capteur. Seuils SC à recalibrer, GARDE_FOU §7) -->
            <node if="$(eval arg('method') == 'bruce_sonar_usbl')"
                  pkg="bruce_slam" name="slam" type="slam_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/slam_caves.yaml" subst_value="true"/>
                <param name="enable_slam" value="true"/>
                <param name="sonar_context/enable" value="true"/>
                <param name="nssm/enable" value="true"/>
                <param name="save_fig" value="false"/>
                <param name="save_data" value="true"/>
                <env name="SLAM_RESULTS_DIR" value="$(optenv SLAM_RESULTS_DIR results)"/>
            </node>

        </group>
        <node pkg="tf" name="map_to_world_tf_publisher" type="static_transform_publisher"
              args="0 0 0 0 0 3.14159 world map 100"/>
    </group>

    <node if="$(arg rviz)" type="rviz" name="rviz" pkg="rviz"
          args="-d $(find bruce_slam)/rviz/video.rviz"/>

</launch>
