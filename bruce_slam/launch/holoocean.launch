<launch>
    <param name="use_sim_time" value="true"/>

    <group ns="bruce">
        <group ns="slam">

            <!-- DVL TwistStamped -> TwistWithCovarianceStamped for robot_localization -->
            <node pkg="bruce_slam" name="dvl_bridge" type="dvl_twist_cov_bridge.py" output="screen"/>

            <!-- DVL+IMU EKF odometry -->
            <node pkg="robot_localization" type="ekf_localization_node" name="ekf_localization"
                  output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/ekf_holoocean.yaml"/>
                <remap from="odometry/filtered" to="/bruce/slam/localization/odom"/>
            </node>

            <!-- HoloOcean polar sonar → OculusPingUncompressed -->
            <node pkg="bruce_slam" name="sonar_bridge" type="holoocean_sonar_bridge.py" output="screen"/>

            <!-- Feature extraction (polar mode) -->
            <node pkg="bruce_slam" name="feature_extraction" type="feature_extraction_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/feature_holoocean.yaml" subst_value="true"/>
            </node>

            <!-- SLAM node -->
            <node pkg="bruce_slam" name="slam" type="slam_node.py" output="screen">
                <rosparam command="load" file="$(find bruce_slam)/config/slam_holoocean.yaml" subst_value="true"/>
                <param name="enable_slam" value="true"/>
                <param name="save_fig" value="false"/>
                <param name="save_data" value="true"/>
                <env name="SLAM_RESULTS_DIR" value="$(find bruce_slam)/../results"/>
            </node>

        </group>
    </group>

    <node type="rviz" name="rviz" pkg="rviz"
          args="-d $(find bruce_slam)/rviz/video.rviz"/>

</launch>
